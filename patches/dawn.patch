diff --git a/absl/base/config.h b/absl/base/config.h
index b707654..3187cbe 100644
--- a/dependencies/dawn/third_party/abseil-cpp/absl/base/config.h
+++ b/dependencies/dawn/third_party/abseil-cpp/absl/base/config.h
@@ -882,16 +882,16 @@ static_assert(ABSL_INTERNAL_INLINE_NAMESPACE_STR[0] != 'h' ||
